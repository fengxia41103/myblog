  <span style="color: #93a8c6;">(</span>add-hook 'c-mode 'annotate-mode<span style="color: #93a8c6;">)</span>
  <span style="color: #93a8c6;">(</span>add-hook 'c++-mode 'annotate-mode<span style="color: #93a8c6;">)</span>
