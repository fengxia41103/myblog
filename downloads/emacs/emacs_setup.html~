         <span style="color: #97b098;">(</span><span style="color: #aebed8;">(</span>org-agenda-todo-ignore-scheduled t<span style="color: #aebed8;">)</span><span style="color: #97b098;">)</span><span style="color: #b0b1a3;">)</span>
